# OpenAI-compatible Chat Completions endpoint
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=deepseek-chat

# Optional
CHORDCODE_SYSTEM_PROMPT=You are a helpful coding agent.
CHORDCODE_DB_PATH=./data/chordcode.sqlite3
CHORDCODE_DEFAULT_WORKTREE=/ABS/PATH/TO/WORKTREE
# Permission default: ask|allow|deny
# Use `allow` for fast local testing only.
CHORDCODE_DEFAULT_PERMISSION_ACTION=ask

# Logging (optional)
CHORDCODE_LOG_LEVEL=INFO
CHORDCODE_LOG_CONSOLE=true
CHORDCODE_LOG_FILE=true
CHORDCODE_LOG_DIR=./data/logs
# Rotate daily at midnight (Loguru syntax)
CHORDCODE_LOG_ROTATION=00:00
# Keep 7 days (Loguru syntax)
CHORDCODE_LOG_RETENTION=7 days
